<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Arselli's Landscape and Design</title>
    <link href="style.css" rel="stylesheet" />
  </head>
  <body>
    <!-- NAV -->
    <nav>
      <a class="nav-logo" href="home.html">Arselli's</a>
      <ul class="nav-links">
        <li><a href="home.html">Home</a></li>
        <li><a href="portfolio.html">Portfolio</a></li>
        <li><a href="/consoltations">Consoltations</a></li>
        <li><a href="#">About</a></li>
        <li><a href="#">Careers</a></li>
        <li><a href="#">Contact</a></li>
      </ul>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-ornament"></div>
      <div class="hero-inner">
        <div class="hero-rule fade-up">
          <span></span>
          <em>Est. 1996 &middot; Chillicothe, Ohio</em>
          <span></span>
        </div>
        <h1 class="fade-up">
          The land reflects the character<br />of those who tend it.
        </h1>
        <p class="hero-sub fade-up">
          Landscape &amp; Design &mdash; Crafted with Integrity
        </p>
        <a href="portfolio.html" class="hero-cta">View Our Work</a>
      </div>
      <div class="hero-scroll">
        <span>Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- INTRO QUOTE BAND -->
    <section class="intro-band">
      <span class="section-label" style="text-align: center; display: block"
        >Our Philosophy</span
      >
      <div class="divider"></div>
      <blockquote>
        "Arselli's has been proud to serve the residents and businesses of
        Chillicothe for over 30 years — by prioritizing relationships and
        integrity within every project."
      </blockquote>
      <div class="divider"></div>
      <cite>Arselli's Landscape &amp; Design</cite>
    </section>

    <!-- THREE PILLARS -->
    <section class="pillars">
      <div class="pillars-header">
        <span class="section-label">What We Offer</span>
        <div class="divider" style="margin: 1rem auto"></div>
        <h2>A standard of excellence,<br />built over three decades.</h2>
      </div>
      <div class="pillars-grid">
        <div class="pillar">
          <div class="pillar-num">I</div>
          <h3>Heritage &amp; Trust</h3>
          <p>
            Over 30 years serving Chillicothe's finest properties. Our
            reputation is built on relationships, not transactions.
          </p>
        </div>
        <div class="pillar">
          <div class="pillar-num">II</div>
          <h3>Custom Design</h3>
          <p>
            Every property is singular. Our designs are drawn from your vision,
            your land, and your way of living.
          </p>
        </div>
        <div class="pillar">
          <div class="pillar-num">III</div>
          <h3>Lasting Craft</h3>
          <p>
            From hardscaping to seasonal care, we apply the same standard of
            excellence across every service we offer.
          </p>
        </div>
      </div>
    </section>

    <!-- TESTIMONIAL -->
    <section class="testimonials">
      <div class="testimonials-inner">
        <span class="section-label">Client Testimonials</span>
        <div class="divider"></div>
        <span class="quote-mark">&ldquo;</span>
        <p class="testimonial-text">
          Arselli's transformed our property into something we are proud to come
          home to every single day. Their attention to detail and genuine care
          for the work is unlike anything we have experienced.
        </p>
        <div class="divider"></div>
        <span class="testimonial-attr"
          >— The Richardson Family &middot; Chillicothe, Ohio</span
        >
      </div>
    </section>

    <!-- CONTACT BAND -->
    <section class="contact-band">
      <div class="contact-inner">
        <div class="contact-item">
          <span class="contact-label">Visit Us</span>
          <p>1410 Alum Cliff Rd<br />Chillicothe, OH 45601</p>
        </div>
        <div class="contact-divider"></div>
        <div class="contact-item">
          <span class="contact-label">Call Us</span>
          <a href="tel:7407758177">(740) 775-8177</a>
        </div>
        <div class="contact-divider"></div>
        <div class="contact-item">
          <span class="contact-label">Online</span>
          <a href="https://arsellislandscape.com">arsellislandscape.com</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <span class="footer-copy"
        >Copyright &copy; 2026 Arselli's Inc. &mdash; All Rights Reserved</span
      >
      <div class="footer-social">
        <a href="#">Facebook</a>
        <a href="#">Instagram</a>
        <a href="#">LinkedIn</a>
      </div>
    </footer>
  </body>
</html>
